# 数据库配置
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=pixaura
DATABASE_PASSWORD=pixaura123
DATABASE_NAME=pixaura

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT 配置
JWT_SECRET=your-jwt-secret-key-change-in-production
JWT_ACCESS_EXPIRATION=2h
JWT_REFRESH_EXPIRATION=7d

# 阿里云短信服务
# 是否启用真实短信发送（true=调用阿里云API，false=仅存入Redis，开发测试用）
SMS_ENABLED=false
ALIYUN_SMS_ACCESS_KEY_ID=your-aliyun-access-key-id
ALIYUN_SMS_ACCESS_KEY_SECRET=your-aliyun-access-key-secret
ALIYUN_SMS_SIGN_NAME=your-sms-sign-name
ALIYUN_SMS_TEMPLATE_CODE_LOGIN=100001
ALIYUN_SMS_TEMPLATE_CODE_REGISTER=100001
ALIYUN_SMS_TEMPLATE_CODE_RESET_PASSWORD=100003
ALIYUN_SMS_TEMPLATE_CODE_CHANGE_PHONE=100005

# 阿里云 OSS
OSS_REGION=cn-hangzhou
OSS_ACCESS_KEY_ID=your-oss-access-key-id
OSS_ACCESS_KEY_SECRET=your-oss-access-key-secret
OSS_BUCKET=your-bucket-name
OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com

# 存储配置
# STORAGE_TYPE: oss | local
STORAGE_TYPE=local
# 本地存储路径（仅 STORAGE_TYPE=local 时生效）
LOCAL_STORAGE_DIR=./uploads

# SMTP 邮件配置
MAIL_SMTP_HOST=smtp.163.com
MAIL_SMTP_PORT=465
MAIL_SMTP_SECURE=true
MAIL_FROM_ADDRESS=your-email@163.com
MAIL_FROM_NAME=Pixaura
MAIL_FROM_PASSWORD=your-email-auth-code

# 应用配置
APP_PORT=3000
APP_ENV=development
APP_URL=http://localhost:3000
WEB_URL=http://localhost:5173

# ngrok 内网穿透（Docker 部署必需，用于外部回调服务获取公网 URL）
# 获取地址：https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=your-ngrok-authtoken

# 数据库兼容变量（种子脚本使用，entrypoint.sh 会自动从 DATABASE_* 变量映射）
# 本地开发无需手动设置，Docker 部署时由 entrypoint.sh 自动处理
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=pixaura
# DB_PASS=pixaura123
# DB_NAME=pixaura
