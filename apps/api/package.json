{
  "name": "@pixaura/api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "nest build",
    "prebuild": "pnpm --filter=@pixaura/shared-types exec node scripts/check-build.mjs || pnpm --filter=@pixaura/shared-types build",
    "predev": "pnpm --filter=@pixaura/shared-types exec node scripts/check-build.mjs || pnpm --filter=@pixaura/shared-types build",
    "dev": "nest start --watch",
    "start": "nest start",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "db:migrate": "ts-node src/database/run-migrations.ts",
    "db:migrate:revert": "typeorm migration:revert -d src/data-source.ts",
    "db:generate": "typeorm migration:generate -d src/data-source.ts",
    "db:seed": "ts-node src/database/seeds/seed.ts",
    "db:seed:encryption": "ts-node src/database/seeds/encryption-key.seed.ts"
  },
  "dependencies": {
    "@alicloud/dypnsapi20170525": "^2.0.0",
    "@alicloud/openapi-client": "^0.4.15",
    "@alicloud/tea-util": "^1.4.11",
    "@fastify/cookie": "^9.4.0",
    "@fastify/multipart": "^8.3.0",
    "@fastify/static": "^7.0.4",
    "@nestjs/bullmq": "^10.2.3",
    "@nestjs/common": "^10.4.0",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/platform-fastify": "^10.4.0",
    "@nestjs/platform-socket.io": "^10.4.0",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/swagger": "^7.4.0",
    "@nestjs/typeorm": "^10.0.2",
    "@nestjs/websockets": "^10.4.0",
    "@pixaura/shared-types": "workspace:*",
    "@volcengine/openapi": "^1.36.0",
    "ali-oss": "^6.22.0",
    "argon2": "^0.41.1",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.70.4",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^17.3.1",
    "fastify": "^4.28.1",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "nest-commander": "^3.20.1",
    "nodemailer": "^6.9.16",
    "pg": "^8.13.1",
    "redlock": "5.0.0-beta.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.7.0",
    "typeorm": "^0.3.20",
    "uuid": "^11.0.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@nestjs/cli": "^10.4.0",
    "@nestjs/schematics": "^10.2.0",
    "@nestjs/testing": "^10.4.22",
    "@types/ali-oss": "^6.16.11",
    "@types/bcryptjs": "^2.4.6",
    "@types/eslint": "^9.6.1",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.13.8",
    "@types/nodemailer": "^6.4.17",
    "@types/uuid": "^10.0.0",
    "eslint": "^10.0.2",
    "globals": "^17.4.0",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.56.1"
  }
}
