{
  "name": "@pixaura/web",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "predev": "pnpm --filter=@pixaura/shared-types exec node scripts/check-build.mjs || pnpm --filter=@pixaura/shared-types build",
    "build": "vue-tsc && vite build",
    "prebuild": "pnpm --filter=@pixaura/shared-types exec node scripts/check-build.mjs || pnpm --filter=@pixaura/shared-types build",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint . --ext .vue,.ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{vue,ts,tsx,css,scss}\""
  },
  "dependencies": {
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "@pixaura/shared-types": "workspace:*",
    "@vicons/ionicons5": "^0.13.0",
    "@vueuse/core": "^14.2.1",
    "axios": "^1.7.9",
    "lucide-vue-next": "^0.577.0",
    "mp4box": "^2.3.0",
    "pinia": "^2.3.0",
    "socket.io-client": "^4.8.3",
    "vue": "^3.5.13",
    "vue-draggable-plus": "^0.6.1",
    "vue-router": "^4.5.0",
    "vuedraggable": "^4.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@types/eslint": "^9.6.1",
    "@types/socket.io-client": "^3.0.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/tsconfig": "^0.7.0",
    "canvas": "^3.2.3",
    "eslint": "^10.0.2",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "jsdom": "^29.0.2",
    "naive-ui": "^2.43.2",
    "playwright": "^1.59.1",
    "puppeteer-core": "^24.37.5",
    "sass": "^1.77.8",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.56.1",
    "vite": "^6.0.5",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^2.2.0"
  }
}
