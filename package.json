{
  "name": "pixaura-plus",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@10.5.2",
  "scripts": {
    "build": "pnpm -r build",
    "dev:api": "pnpm --filter=api dev",
    "dev:web": "pnpm --filter=web dev",
    "lint": "pnpm -r lint",
    "format": "pnpm -r format",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "db:up": "docker compose -f docker/docker-compose.yml up -d",
    "db:down": "docker compose -f docker/docker-compose.yml down",
    "db:logs": "docker compose -f docker/docker-compose.yml logs -f",
    "docker:up": "docker compose -f docker/docker-compose.yml --profile full up -d --build",
    "docker:start": "docker compose -f docker/docker-compose.yml --profile full up -d",
    "docker:down": "docker compose -f docker/docker-compose.yml --profile full down",
    "docker:build": "docker compose -f docker/docker-compose.yml --profile full build",
    "docker:logs": "docker compose -f docker/docker-compose.yml --profile full logs -f",
    "db:migrate": "pnpm --filter=api db:migrate",
    "db:migrate:revert": "pnpm --filter=api db:migrate:revert",
    "db:generate": "pnpm --filter=api db:generate",
    "db:seed": "pnpm --filter=api db:seed"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^22.13.8",
    "playwright": "^1.59.1",
    "prettier": "^3.5.3",
    "typescript": "^5.8.2"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  }
}
